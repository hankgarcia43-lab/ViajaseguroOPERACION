PORT=4000
NODE_ENV=development
DATABASE_URL="postgresql://postgres:postgres@localhost:5433/viaja_seguro?schema=public"
JWT_SECRET="change-me-use-a-long-random-value"
JWT_EXPIRES_IN="7d"
CORS_ORIGIN="http://localhost:3000,http://127.0.0.1:3000"

# Bypass de desarrollo. En produccion deben ser false.
AUTO_APPROVE_DRIVERS=false
ENABLE_DEV_DRIVER_AUTO_APPROVE_BYPASS=false
ALLOW_DEV_PAYMENT_SIMULATION=false
CLOSED_PILOT_MODE=true
INVITE_ONLY=true
PUBLIC_REGISTRATION_ENABLED=false
MAX_ACTIVE_DRIVERS=20
MAX_ACTIVE_USERS=100
ALLOWED_MUNICIPALITIES=acolman,ecatepec,tecamac,texcoco,teotihuacan
ALLOWED_DESTINATIONS=indios-verdes,pantitlan,buenavista,ciudad-azteca
ADMIN_SUPERUSER_MODE=false

# Mercado Pago solo para membresias, verificaciones, suscripciones o servicios digitales de plataforma.
MERCADOPAGO_PAYMENT_LINK="https://link.mercadopago.com.mx/viajaseguro2026"
MERCADOPAGO_ACCESS_TOKEN=""
MERCADOPAGO_WEBHOOK_SECRET=""
MERCADOPAGO_WEBHOOK_URL="http://localhost:4000/api/webhooks/mercadopago"
MERCADOPAGO_USE_SANDBOX=true

# Pagos de plataforma por link fijo de Mercado Pago. No publicar CLABE, cuentas bancarias ni datos personales.
MANUAL_PAYMENT_PROCESSOR_LABEL="Mercado Pago"
MANUAL_PAYMENT_REFERENCE="VIAJA SEGURO"
