# Configuracion global de referencia
# Copia estos valores a apps/api/.env y apps/web/.env.local segun corresponda.
# No guardes secretos reales en este archivo.

PORT=4000
NODE_ENV=development
DATABASE_URL="postgresql://postgres:postgres@localhost:5433/viaja_seguro?schema=public"
JWT_SECRET="change-me-use-a-long-random-value"
JWT_EXPIRES_IN="7d"
CORS_ORIGIN="http://localhost:3000,http://127.0.0.1:3000"

# Flags operativos. En produccion deben permanecer en false salvo decision explicita.
ADMIN_SUPERUSER_MODE=false
AUTO_APPROVE_DRIVERS=false
ENABLE_DEV_DRIVER_AUTO_APPROVE_BYPASS=false
ALLOW_DEV_PAYMENT_SIMULATION=false
CLOSED_PILOT_MODE=true
INVITE_ONLY=true
PUBLIC_REGISTRATION_ENABLED=false
TRIAL_DAYS=7
MAX_ACTIVE_DRIVERS=20
MAX_ACTIVE_USERS=100
ALLOWED_MUNICIPALITIES=acolman,ecatepec,tecamac,texcoco,teotihuacan
ALLOWED_DESTINATIONS=indios-verdes,pantitlan,buenavista,ciudad-azteca

# Pagos de plataforma. No publicar CLABE, cuentas bancarias ni datos personales.
# Mercado Pago se usa solo para planes semanales, verificaciones o servicios digitales.
MANUAL_PAYMENT_PROCESSOR_LABEL=Mercado Pago
MANUAL_PAYMENT_REFERENCE=VIAJA SEGURO

# Mercado Pago. El piloto usa link fijo solo para planes semanales/verificaciones de plataforma.
MERCADOPAGO_PAYMENT_LINK="https://link.mercadopago.com.mx/viajaseguro2026"
MERCADOPAGO_ACCESS_TOKEN=""
MERCADOPAGO_WEBHOOK_SECRET=""
MERCADOPAGO_WEBHOOK_URL="http://localhost:4000/api/webhooks/mercadopago"
MERCADOPAGO_USE_SANDBOX=true
MERCADOPAGO_SUBSCRIPTION_AMOUNT=150
MERCADOPAGO_SUBSCRIPTION_DAYS=7
FRONTEND_URL="http://localhost:3000"

# Frontend.
NEXT_PUBLIC_API_URL="http://localhost:4000/api"
NEXT_PUBLIC_MP_PAYMENT_LINK=https://link.mercadopago.com.mx/viajaseguro2026
NEXT_PUBLIC_MP_PAYMENT_REFERENCE=VIAJA SEGURO
NEXT_PUBLIC_ENABLE_DEV_PAYMENT_SIMULATION=false
NEXT_PUBLIC_COMPANY_NAME=VIAJA SEGURO
NEXT_PUBLIC_SUPPORT_EMAIL=soporte@viajaseguro.mx
NEXT_PUBLIC_SUPPORT_WHATSAPP=+525500000000
NEXT_PUBLIC_DEFAULT_CURRENCY=MXN
NEXT_PUBLIC_DEFAULT_LOCALE=es-MX
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=

# Proxy opcional de Next.js para llamadas servidor-a-servidor.
API_PROXY_TARGET=http://localhost:4000/api
API_PROXY_TIMEOUT_MS=15000
